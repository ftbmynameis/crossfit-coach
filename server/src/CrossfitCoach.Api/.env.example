# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit it.

# PostgreSQL connection string (Neon dev database)
# Key=value format required (URI format not supported by Npgsql)
DATABASE_URL=Host=your-neon-host.neon.tech;Database=neondb;Username=neondb_owner;Password=your-password;SSL Mode=Require
