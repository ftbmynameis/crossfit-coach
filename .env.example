# CrossFit Coach — environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# PostgreSQL connection string from Neon (added in TASK-006)
DATABASE_URL=

# Google OAuth2 credentials (added in TASK-008)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign short-lived JWTs — generate with: openssl rand -base64 64 (added in TASK-008)
JWT_SECRET=

# Email address that receives all permissions on first login (added in TASK-008)
ALLOWED_USER_EMAIL=

# Allowed CORS origin — set to your Vercel frontend URL (e.g. https://your-app.vercel.app)
# Defaults to http://localhost:4200 if not set
ALLOWED_ORIGIN=

# Set to Development to enable Swagger UI and dev-only features
ASPNETCORE_ENVIRONMENT=Development

# Binding address — Render sets $PORT automatically, leave as-is for production
ASPNETCORE_URLS=http://+:$PORT
